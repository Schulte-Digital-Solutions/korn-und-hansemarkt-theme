{
  "apiVersion": 3,
  "name": "kuh/drop-cap-paragraph",
  "version": "1.0.0",
  "title": "Initial-Absatz",
  "category": "text",
  "icon": "editor-textcolor",
  "description": "Absatz mit dekorativem Großbuchstaben (Initial / Drop Cap) am Anfang.",
  "keywords": ["initial", "drop cap", "großbuchstabe", "absatz", "paragraph"],
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "anchor": true,
    "spacing": {
      "padding": true,
      "margin": true,
      "__experimentalDefaultControls": {
        "padding": true,
        "margin": true
      }
    }
  },
  "attributes": {
    "text": {
      "type": "string",
      "source": "html",
      "selector": "p",
      "default": ""
    },
    "dropCapColor": {
      "type": "string",
      "default": ""
    },
    "dropCapFont": {
      "type": "string",
      "default": "gothic",
      "enum": ["gothic", "serif", "inherit"]
    },
    "maxWidth": {
      "type": "string",
      "default": "65ch"
    }
  },
  "textdomain": "korn-und-hansemarkt",
  "editorScript": "file:./editor.js",
  "render": "file:./render.php"
}
