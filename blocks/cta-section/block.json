{
  "apiVersion": 3,
  "name": "kuh/cta-section",
  "version": "1.0.0",
  "title": "CTA-Sektion",
  "category": "design",
  "icon": "megaphone",
  "description": "Call-to-Action Sektion mit dunkelgrünem Hintergrund, Headline und Button.",
  "keywords": ["cta", "call-to-action", "mitmachen", "aktion"],
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "anchor": true
  },
  "attributes": {
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "overlayOpacity": {
      "type": "number",
      "default": 85
    }
  },
  "textdomain": "korn-und-hansemarkt",
  "editorScript": "file:./editor.js",
  "render": "file:./render.php"
}
