		"typography": {
			"customFontSize": false,
			"fontFamilies": [
				{
					"fontFamily": "'Plus Jakarta Sans', 'Inter', sans-serif",
					"slug": "body",
					"name": "Body (Plus Jakarta Sans)"
				},
				{
					"fontFamily": "'UnifrakturMaguntia', 'Manuskript Gotisch', serif",
					"slug": "headline",
					"name": "Headline (Fraktur)"
				},
				{
					"fontFamily": "'Newsreader', Georgia, serif",
					"slug": "serif-italic",
					"name": "Serif Italic (Newsreader)"
				},
				{
					"fontFamily": "'Inter', sans-serif",
					"slug": "inter",
					"name": "Inter"
				},
				{
					"fontFamily": "'Manuskript Gotisch', serif",
					"slug": "manuskript-gotisch",
					"name": "Manuskript Gotisch"
				},
				{
					"fontFamily": "system-ui, sans-serif",
					"slug": "system-ui",
					"name": "System (Standard)"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Klein"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Normal"
				},
				{
					"slug": "large",
					"size": "1.25rem",
					"name": "Groß"
				},
				{
					"slug": "x-large",
					"size": "1.5rem",
					"name": "Extra groß"
				},
				{
					"slug": "xx-large",
					"size": "2.25rem",
					"name": "Riesig"
				}
			]
		},
		"spacing": {
			"units": [ "px", "rem", "%", "vw" ],
			"spacingSizes": [
				{
					"slug": "10",
					"size": "0.5rem",
					"name": "XS"
				},
				{
					"slug": "20",
					"size": "1rem",
					"name": "S"
				},
				{
					"slug": "30",
					"size": "1.5rem",
					"name": "M"
				},
				{
					"slug": "40",
					"size": "2rem",
					"name": "L"
				},
				{
					"slug": "50",
					"size": "3rem",
					"name": "XL"
				},
				{
					"slug": "60",
					"size": "4rem",
					"name": "XXL"
				}
			]
		},
		"appearanceTools": true
	},
	"styles": {
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--on-primary)"
				},
				"border": {
					"radius": "9999px",
					"width": "2px",
					"style": "solid",
					"color": "currentColor"
				},
				"spacing": {
					"padding": {
						"top": "0.625rem",
						"bottom": "0.625rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				"typography": {
					"fontWeight": "600",
					"textTransform": "uppercase",
					"letterSpacing": "0.05em",
					"fontSize": "0.875rem"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-container)",
						"text": "var(--wp--preset--color--on-primary-container)"
					},
					"border": {
						"color": "currentColor"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--primary-container)",
						"text": "var(--wp--preset--color--on-primary-container)"
					}
				}
			}
		}
	}
}
